\makeatletter
\newcount\progressbar@tmpcounta% auxiliary counter
\newcount\progressbar@tmpcountb% auxiliary counter
\newdimen\progressbar@pbwidth %progressbar width
\newdimen\progressbar@tmpdim % auxiliary dimension

\newdimen\slidewidth % auxiliary dimension
\newdimen\slideheight % auxiliary dimension

% make the progress bar go across the screen
\progressbar@pbwidth=\the\paperwidth
\slidewidth=\the\paperwidth
\slideheight=\the\paperheight

\newcommand{\makeProgress}{
  \ifnum\thepage>1\relax % skip title page
    \ifnum\showProgressBar=1\relax%
      % progress bar icon in the middle of the screen
      \draw[fill=black!85!color_2,draw=none] (0,12pt) rectangle(\slidewidth,13pt+0.25cm);
      \draw[fill=black!75!color_2,draw=none] (0,12pt) rectangle(\progressbar@tmpdim,13pt+0.25cm);
    \fi
    % bottom info
    \ifnum\showSectionTitles=1\relax
      \node[anchor=south west] at(0cm,0.28cm) {\color{color_2!80!black}\tiny\insertsection};
    \fi
    % if slide numbers are active
    \ifnum\showSlideNumbers=1\relax%
      % if slide totals are active
      \ifnum\showSlideTotal=1\relax%
        % draw both slide number and slide total
        \node[anchor=south east] at(\slidewidth,0.28cm) {\color{color_2!80!black}\tiny\insertframenumber/\inserttotalframenumber};
      \else
        \node[anchor=south east] at(\slidewidth,0.28cm) {\color{color_2!80!black}\tiny\insertframenumber};
      \fi
    \fi
  \fi
}





