% remaking the parchment environment without the mandatory title box bc i dont like it
\newenvironment{parchment}[1][\@nil]{%
  \def\FrameCommand{\parchmentframe}%
  \def\FirstFrameCommand{\parchmentframetop}%
  \def\LastFrameCommand{\parchmentframebottom}%
  \def\MidFrameCommand{\parchmentframemiddle}%
  \vskip\baselineskip
  \MakeFramed {\FrameRestore}
  \def\tmp{#1}
  \ifx\tmp\@nnil
  % blabla
  \else
  \noindent\tikz\node[inner sep=1ex, draw=darkbeige!60, fill=black!70!gray, 
           anchor=west, overlay] at (0em, 2em) {\sffamily#1};
    \fi
\par
}
{\endMakeFramed}

